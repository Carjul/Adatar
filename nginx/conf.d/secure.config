server {
  listen 80;
  server_name 173-230-132-232.ip.linodeusercontent.com;
  return 301 https://$server_name$request_uri;
}

server {
  listen 443 ssl;
  server_name 173-230-132-232.ip.linodeusercontent.com;

    ssl_certificate /root/cert.pem;
    ssl_certificate_key /root/key.pem;

  location / {
    proxy_pass http://172.17.0.1:3004;
  }
}
